{
  "expo": {
    "name": "TransHougen",
    "slug": "transhougen",
    "version": "1.0.0",
    "orientation": "default",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "jsEngine": "hermes",
    "userInterfaceStyle": "automatic",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "方言の音声入力（文字起こし）にマイクを使用します。"
        }
      ]
    ]
  }
}
